<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Matilda Photo Booth</title>
<style>
* { margin:0; padding:0; box-sizing:border-box; }
body { background:#111; display:flex; flex-direction:column; align-items:center; justify-content:center; height:100vh; overflow:hidden; font-family:Georgia,serif; }

/* ── Stage ── */
#stage {
  position: relative;
  width: min(92vw, 88vh * 1.249);
  aspect-ratio: 1402 / 1122;
  flex-shrink: 0;
}

/* Single shared video fills stage, hidden behind artwork */
#bg-video {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  transform: scaleX(-1);
  opacity: 0; /* invisible — only used to feed the holes */
  pointer-events: none;
  z-index: 0;
}

/* Artwork overlay — on top of everything, pointer-events off */
#artwork {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: fill;
  z-index: 20;
  pointer-events: none;
}

/* Face holes */
.hole {
  position: absolute;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  overflow: hidden;
  z-index: 10;
}
.hole-inner {
  width: 100%; height: 100%;
  border-radius: 50%;
  overflow: hidden;
  background: #444;
}
/* Each hole gets its own video element sharing the same stream */
.hole video {
  width: 100%; height: 100%;
  object-fit: cover;
  transform: scaleX(-1);
  display: block;
  border-radius: 50%;
}
.hole-label {
  position: absolute;
  bottom: -22px; left: 50%;
  transform: translateX(-50%);
  white-space: nowrap;
  font-size: clamp(8px,1.1vw,13px);
  color: #fff;
  background: rgba(0,0,0,.6);
  padding: 1px 7px;
  border-radius: 8px;
  pointer-events: none;
}

/* ── Controls ── */
#bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 14px 20px;
  background: linear-gradient(transparent, rgba(0,0,0,.95));
  display: flex; align-items: center; justify-content: center; gap: 16px;
  z-index: 50;
}
.btn {
  border: none; border-radius: 40px;
  padding: 12px 36px;
  font-family: Georgia,serif;
  font-size: clamp(13px,1.8vw,20px);
  cursor: pointer;
  transition: transform .15s, opacity .15s;
}
#snapBtn { background:#e63946; color:#fff; box-shadow:0 0 24px rgba(230,57,70,.5); }
#snapBtn:hover:not(:disabled) { transform:scale(1.05); }
#snapBtn:disabled { opacity:.4; cursor:not-allowed; }
#retakeBtn { display:none; background:rgba(255,255,255,.15); color:#fff; border:1px solid rgba(255,255,255,.3); }

/* ── Countdown ── */
#cd {
  position: fixed; top:50%; left:50%;
  transform: translate(-50%,-55%);
  font-size: 28vw; color: rgba(255,255,255,.9);
  text-shadow: 0 0 60px rgba(230,57,70,.8);
  pointer-events: none; z-index: 80; display: none;
}

/* ── Flash ── */
#flash { position:fixed; inset:0; background:#fff; opacity:0; pointer-events:none; z-index:90; transition:opacity .06s; }

/* ── Result overlay ── */
#result {
  display: none; position: fixed; inset: 0;
  background: rgba(0,0,0,.92); z-index: 100;
  flex-direction: column; align-items: center; justify-content: center; gap: 16px;
}
#result.show { display: flex; }
#resultImg { max-width:88vw; max-height:76vh; border-radius:8px; box-shadow:0 8px 48px rgba(0,0,0,.7); }
.rbtn { border:none; border-radius:40px; padding:12px 32px; font-family:Georgia,serif; font-size:16px; cursor:pointer; }
#dlBtn { background:#e63946; color:#fff; }
#dlBtn:hover { background:#c1121f; }
#closeBtn { background:rgba(255,255,255,.15); color:#fff; border:1px solid rgba(255,255,255,.3); }

/* ── Toast ── */
#toast {
  position: fixed; top:0; left:0; right:0;
  padding: 12px 20px; font-size:15px; text-align:center;
  z-index: 999; display:none; line-height:1.5;
}
#toast.info { background:#2a9d8f; color:#fff; display:block; }
#toast.error { background:#e63946; color:#fff; display:block; }
</style>
</head>
<body>

<div id="toast"></div>

<div id="stage">
  
    <div class="hole" style="left:22.47%;top:24.51%;width:17.84%;height:24.96%;" data-name="Miss Trunchbull">
      <div class="hole-inner"></div>
      <span class="hole-label">Miss Trunchbull</span>
    </div>
    <div class="hole" style="left:55.99%;top:32.98%;width:19.98%;height:26.74%;" data-name="Miss Honey">
      <div class="hole-inner"></div>
      <span class="hole-label">Miss Honey</span>
    </div>
    <div class="hole" style="left:73.11%;top:24.51%;width:17.84%;height:24.96%;" data-name="Mr Wormwood">
      <div class="hole-inner"></div>
      <span class="hole-label">Mr Wormwood</span>
    </div>
    <div class="hole" style="left:15.34%;top:69.07%;width:13.56%;height:18.72%;" data-name="Bruce Bogtrotter">
      <div class="hole-inner"></div>
      <span class="hole-label">Bruce Bogtrotter</span>
    </div>
    <div class="hole" style="left:39.94%;top:43.67%;width:13.56%;height:18.72%;" data-name="Matilda">
      <div class="hole-inner"></div>
      <span class="hole-label">Matilda</span>
    </div>
    <div class="hole" style="left:66.33%;top:67.29%;width:17.84%;height:24.96%;" data-name="Mrs Wormwood">
      <div class="hole-inner"></div>
      <span class="hole-label">Mrs Wormwood</span>
    </div>
  <img id="artwork" src="data:image/jpeg;base64," alt="Matilda booth">
</div>

<div id="bar">
  <button class="btn" id="snapBtn" onclick="startCountdown()" disabled>📸 Take Photo!</button>
  <button class="btn" id="retakeBtn" onclick="retake()">↩ Retake</button>
</div>

<div id="cd"></div>
<div id="flash"></div>

<div id="result">
  <img id="resultImg" src="" alt="Your photo">
  <div style="display:flex;gap:14px;flex-wrap:wrap;justify-content:center">
    <button class="rbtn" id="dlBtn" onclick="download()">⬇ Save Photo</button>
    <button class="rbtn" id="closeBtn" onclick="closeResult()">✕ Close</button>
  </div>
</div>

<script>
const FACES = [
  {name:"Miss Trunchbull",cx:22.47,cy:24.51,rw:8.92,rh:12.48},
  {name:"Miss Honey",cx:55.99,cy:32.98,rw:9.99,rh:13.37},
  {name:"Mr Wormwood",cx:73.11,cy:24.51,rw:8.92,rh:12.48},
  {name:"Bruce Bogtrotter",cx:15.34,cy:69.07,rw:6.78,rh:9.36},
  {name:"Matilda",cx:39.94,cy:43.67,rw:6.78,rh:9.36},
  {name:"Mrs Wormwood",cx:66.33,cy:67.29,rw:8.92,rh:12.48}
];
const IW = 1402, IH = 1122;

let stream = null;
let frozenUrl = null;

function toast(msg, type, ms) {
  const el = document.getElementById('toast');
  el.textContent = msg; el.className = type;
  if (ms) setTimeout(() => { el.className = ''; }, ms);
}

async function init() {
  try {
    stream = await navigator.mediaDevices.getUserMedia({
      video: { width:{ideal:1280}, height:{ideal:720}, facingMode:'user' },
      audio: false
    });

    // Give each hole its own <video> element — all sharing the same stream
    document.querySelectorAll('.hole').forEach(hole => {
      const inner = hole.querySelector('.hole-inner');
      const v = document.createElement('video');
      v.srcObject = stream;
      v.autoplay = true; v.playsInline = true; v.muted = true;
      inner.appendChild(v);
      v.play().catch(e => console.warn('video play:', e));
    });

    document.getElementById('snapBtn').disabled = false;
    toast('✅ Camera ready! Step in front and take your photo.', 'info', 3500);
  } catch(e) {
    const msg = e.name === 'NotAllowedError'
      ? '🚫 Camera blocked — click the camera icon in the address bar and Allow, then refresh'
      : e.name === 'NotFoundError'
      ? '🔌 No camera found — plug in a webcam and refresh'
      : e.name === 'NotReadableError'
      ? '📵 Camera in use by another app — close Zoom/FaceTime and refresh'
      : '❌ Camera error: ' + e.name + ' — ' + e.message;
    toast(msg, 'error');
    console.error(e);
  }
}

// ── Capture: draw frame onto canvas, export PNG ──────────────────────
function startCountdown() {
  document.getElementById('snapBtn').disabled = true;
  const el = document.getElementById('cd'); el.style.display = 'block';
  let n = 3;
  const tick = () => {
    el.textContent = n;
    if (n === 0) { el.style.display = 'none'; doSnap(); return; }
    n--; setTimeout(tick, 900);
  };
  tick();
}

async function doSnap() {
  // Flash
  const fl = document.getElementById('flash');
  fl.style.opacity = '1';
  setTimeout(() => fl.style.opacity = '0', 160);

  const stage = document.getElementById('stage');
  const sw = stage.offsetWidth, sh = stage.offsetHeight;

  // Work at 2× for retina but cap at native image size
  const scale = Math.min(IW / sw, 2);
  const cw = Math.round(sw * scale), ch = Math.round(sh * scale);

  const canvas = document.createElement('canvas');
  canvas.width = cw; canvas.height = ch;
  const ctx = canvas.getContext('2d');

  // 1. Draw each webcam feed into its ellipse at canvas scale
  const videos = document.querySelectorAll('.hole video');
  FACES.forEach((f, i) => {
    const v = videos[i];
    if (!v || v.readyState < 2) return;
    const cx = f.cx / 100 * cw;
    const cy = f.cy / 100 * ch;
    const rw = f.rw / 100 * cw;
    const rh = f.rh / 100 * ch;

    ctx.save();
    ctx.beginPath();
    ctx.ellipse(cx, cy, rw, rh, 0, 0, Math.PI * 2);
    ctx.clip();

    ctx.translate(cx, cy);
    ctx.scale(-1, 1); // mirror to match display

    const vw = v.videoWidth || 640, vh = v.videoHeight || 480;
    const s = Math.max((rw * 2) / vw, (rh * 2) / vh) * 1.05;
    ctx.drawImage(v, -vw * s / 2, -vh * s / 2, vw * s, vh * s);
    ctx.restore();
  });

  // 2. Draw artwork on top — this taints canvas BUT we handle it
  const artImg = document.getElementById('artwork');

  // Draw it — if this taints canvas, catch the error on toDataURL
  ctx.drawImage(artImg, 0, 0, cw, ch);

  try {
    frozenUrl = canvas.toDataURL('image/png');
    document.getElementById('resultImg').src = frozenUrl;
    document.getElementById('result').classList.add('show');
    document.getElementById('retakeBtn').style.display = 'inline-block';
    document.getElementById('snapBtn').style.display = 'none';
  } catch(e) {
    // Canvas tainted — fall back: export without artwork overlay, just the faces
    console.warn('Canvas tainted, trying fallback:', e);
    // Clear and redraw only webcam (no booth image)
    ctx.clearRect(0, 0, cw, ch);
    ctx.fillStyle = '#87CEEB'; // sky blue background
    ctx.fillRect(0, 0, cw, ch);
    FACES.forEach((f, i) => {
      const v = videos[i];
      if (!v || v.readyState < 2) return;
      const cx = f.cx / 100 * cw, cy = f.cy / 100 * ch;
      const rw = f.rw / 100 * cw, rh = f.rh / 100 * ch;
      ctx.save();
      ctx.beginPath();
      ctx.ellipse(cx, cy, rw, rh, 0, 0, Math.PI * 2);
      ctx.clip();
      ctx.translate(cx, cy); ctx.scale(-1, 1);
      const vw = v.videoWidth||640, vh = v.videoHeight||480;
      const s = Math.max((rw*2)/vw,(rh*2)/vh)*1.05;
      ctx.drawImage(v, -vw*s/2, -vh*s/2, vw*s, vh*s);
      ctx.restore();
    });
    try {
      frozenUrl = canvas.toDataURL('image/png');
      document.getElementById('resultImg').src = frozenUrl;
      document.getElementById('result').classList.add('show');
      document.getElementById('retakeBtn').style.display = 'inline-block';
      document.getElementById('snapBtn').style.display = 'none';
      toast('Note: saved without artwork overlay due to browser security. For full image use localhost server.', 'error', 8000);
    } catch(e2) {
      toast('Could not save photo: ' + e2.message, 'error');
      retake();
    }
  }
}

function retake() {
  frozenUrl = null;
  document.getElementById('result').classList.remove('show');
  document.getElementById('snapBtn').style.display = 'inline-block';
  document.getElementById('snapBtn').disabled = false;
  document.getElementById('retakeBtn').style.display = 'none';
}

function closeResult() {
  document.getElementById('result').classList.remove('show');
}

function download() {
  if (!frozenUrl) return;
  const a = document.createElement('a');
  a.download = 'matilda-booth-' + Date.now() + '.png';
  a.href = frozenUrl; a.click();
}

window.addEventListener('load', init);
</script>
</body>
</html>